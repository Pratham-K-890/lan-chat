<?xml version="1.0" encoding="utf-8"?>
<!--
    Reusable auth form included inside panelHostReady and panelJoining.
    IDs accessed via includeAuthHost.* and includeAuthJoin.* in LoginActivity.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="[ IDENTIFIER ]"
        android:textSize="11sp"
        android:textColor="@color/on_surface"
        android:fontFamily="monospace"
        android:letterSpacing="0.05" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface_container_low"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&gt; "
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary_white"
            android:fontFamily="monospace" />

        <EditText
            android:id="@+id/etUsername"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="USERNAME:"
            android:textColorHint="@color/on_surface_variant"
            android:textColor="@color/primary_white"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:inputType="textNoSuggestions"
            android:singleLine="true"
            android:background="@null"
            android:textAllCaps="false" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="[ ACCESS_KEY ]"
        android:textSize="11sp"
        android:textColor="@color/on_surface"
        android:fontFamily="monospace"
        android:letterSpacing="0.05" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface_container_low"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&gt; "
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary_white"
            android:fontFamily="monospace" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="PASSWORD:"
            android:textColorHint="@color/on_surface_variant"
            android:textColor="@color/primary_white"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:inputType="textPassword"
            android:singleLine="true"
            android:background="@null" />
    </LinearLayout>

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="[ EXECUTE_LOGIN ]"
        android:textColor="@color/on_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:letterSpacing="0.08"
        android:backgroundTint="@color/primary_white"
        style="@style/Widget.MaterialComponents.Button" />

    <Button
        android:id="@+id/btnRegister"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="&gt; REGISTER_NEW_NODE"
        android:textColor="@color/on_surface_variant"
        android:textSize="11sp"
        android:fontFamily="monospace"
        style="@style/Widget.MaterialComponents.Button.TextButton" />

</LinearLayout>
