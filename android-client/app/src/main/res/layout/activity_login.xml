<?xml version="1.0" encoding="utf-8"?>
<!--
    Login screen — HOST/JOIN entry point.
    State panels controlled by LoginActivity.kt visibility switches:
      panelModeSelect  → initial HOST / JOIN choice
      panelHostReady   → server started, shows IP + auth form
      panelJoining     → scanning for host + manual IP fallback + auth form
      panelAuth        → username/password (shown inside host & join panels)
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep"
    android:fitsSystemWindows="true">

    <!-- ── Fixed top bar ────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/bg_bar"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⬛"
            android:textSize="14sp"
            android:textColor="@color/primary_white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="[ DIRECTORY: ROOT/CHATS ]"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/primary_white"
            android:fontFamily="monospace"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/tvTopStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[ SIG: ENCRYPTED ]"
            android:textSize="10sp"
            android:textColor="@color/on_surface_variant"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- ── Scrollable body ─────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingTop="48dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="40dp">

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="[ INITIALIZING_SESSION... ]"
                android:textSize="11sp"
                android:textColor="@color/on_surface_variant"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="[SYSTEM_LOGIN]"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/primary_white"
                android:fontFamily="monospace"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="0x0001: SELECT_OPERATION_MODE"
                android:textSize="11sp"
                android:textColor="@color/on_surface_variant"
                android:fontFamily="monospace" />

            <!-- Decorative log lines -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:alpha="0.35">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="> LOADING_LIBS... OK" android:textSize="10sp"
                    android:textColor="@color/on_surface_variant" android:fontFamily="monospace" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="> SECURING_TUNNEL... [ AES-256 ]" android:textSize="10sp"
                    android:textColor="@color/on_surface_variant" android:fontFamily="monospace" />
            </LinearLayout>

            <!-- ══════════════════════════════════════════════
                 PANEL 1: MODE SELECT (HOST / JOIN)
                 Shown first. Hidden once mode chosen.
                 ══════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/panelModeSelect"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="[ SELECT_OPERATION_MODE ]"
                    android:textSize="11sp"
                    android:textColor="@color/on_surface_variant"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.05" />

                <!-- HOST button -->
                <Button
                    android:id="@+id/btnHost"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginTop="16dp"
                    android:text="[ HOST SESSION ]"
                    android:textColor="@color/on_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    android:backgroundTint="@color/primary_white"
                    style="@style/Widget.MaterialComponents.Button" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:text="Start the chat server on THIS phone.\nOthers connect to you."
                    android:textSize="11sp"
                    android:textColor="@color/on_surface_variant"
                    android:fontFamily="monospace"
                    android:gravity="center" />

                <!-- Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginVertical="16dp">
                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="@color/outline_variant" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        android:text="OR" android:textSize="10sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="monospace" />
                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="@color/outline_variant" />
                </LinearLayout>

                <!-- JOIN button -->
                <Button
                    android:id="@+id/btnJoin"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:text="[ JOIN SESSION ]"
                    android:textColor="@color/primary_white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    android:backgroundTint="@color/surface_container_low"
                    style="@style/Widget.MaterialComponents.Button" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Find and join an existing host\non the same WiFi / hotspot."
                    android:textSize="11sp"
                    android:textColor="@color/on_surface_variant"
                    android:fontFamily="monospace"
                    android:gravity="center" />

            </LinearLayout>

            <!-- ══════════════════════════════════════════════
                 PANEL 2: HOST READY
                 Shown after server starts successfully.
                 ══════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/panelHostReady"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp"
                android:visibility="gone">

                <!-- Server status badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/surface_container_low"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SERVER_STATUS"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tvServerStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="[ STARTING... ]"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_white"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Host IP display — big and prominent -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/primary_white"
                    android:padding="20dp"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YOUR IP — SHARE THIS"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_primary"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvHostIp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0.0.0.0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_primary"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Port: 9090  •  Auto-discovery: ON"
                        android:textSize="11sp"
                        android:textColor="@color/on_primary"
                        android:fontFamily="monospace"
                        android:alpha="0.7" />
                </LinearLayout>

                <!-- Progress bar for server starting -->
                <ProgressBar
                    android:id="@+id/progressServer"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/primary_white"
                    android:layout_marginTop="4dp"
                    android:visibility="visible" />

                <!-- Auth form (inline, shown once server is RUNNING) -->
                <include
                    android:id="@+id/includeAuthHost"
                    layout="@layout/include_auth_form"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:visibility="gone" />

                <!-- Back button -->
                <Button
                    android:id="@+id/btnStopHost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="&gt; STOP_SERVER"
                    android:textColor="@color/error_container"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

            </LinearLayout>

            <!-- ══════════════════════════════════════════════
                 PANEL 3: JOIN
                 Auto-discovery scanning + manual IP fallback.
                 ══════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/panelJoining"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp"
                android:visibility="gone">

                <!-- Scanning status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/surface_container_low"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SCANNING_FOR_HOST..."
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="monospace" />

                    <ProgressBar
                        android:id="@+id/progressScan"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:indeterminateTint="@color/primary_white" />
                </LinearLayout>

                <!-- Auto-discovered host banner (hidden until found) -->
                <LinearLayout
                    android:id="@+id/panelFoundHost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/primary_white"
                    android:padding="16dp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HOST FOUND"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_primary"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvFoundIp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0.0.0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_primary"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnConnectFound"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONNECT"
                        android:textColor="@color/bg_deep"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:backgroundTint="@color/on_primary"
                        style="@style/Widget.MaterialComponents.Button" />
                </LinearLayout>

                <!-- Manual IP divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginVertical="16dp">
                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="@color/outline_variant" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        android:text="OR ENTER MANUALLY" android:textSize="10sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="monospace" />
                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="@color/outline_variant" />
                </LinearLayout>

                <!-- Manual IP input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="[ SERVER_NODE ]"
                    android:textSize="11sp"
                    android:textColor="@color/on_surface"
                    android:fontFamily="monospace" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/surface_container_low"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&gt; "
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_white"
                        android:fontFamily="monospace" />

                    <EditText
                        android:id="@+id/etServerIp"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="192.168.x.x"
                        android:textColorHint="@color/on_surface_variant"
                        android:textColor="@color/primary_white"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:inputType="textUri"
                        android:singleLine="true"
                        android:background="@null"
                        android:imeOptions="actionDone" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnConnectManual"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="[ EXECUTE_CONNECT ]"
                    android:textColor="@color/on_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.08"
                    android:backgroundTint="@color/primary_white"
                    style="@style/Widget.MaterialComponents.Button" />

                <!-- Auth form (shown after connected) -->
                <include
                    android:id="@+id/includeAuthJoin"
                    layout="@layout/include_auth_form"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:visibility="gone" />

                <!-- Back button -->
                <Button
                    android:id="@+id/btnBackFromJoin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="&gt; BACK"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

            </LinearLayout>

            <!-- ── Footer log (decorative) ────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="32dp"
                android:alpha="0.25">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0x7F001: PING 4ms" android:textSize="10sp"
                        android:textColor="@color/on_surface_variant" android:fontFamily="monospace" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0x7F002: TRACE COMPLETE" android:textSize="10sp"
                        android:textColor="@color/on_surface_variant" android:fontFamily="monospace" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="end">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="LOC: NODE_LAN" android:textSize="10sp"
                        android:textColor="@color/on_surface_variant" android:fontFamily="monospace" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PROTO: TCP/9090" android:textSize="10sp"
                        android:textColor="@color/on_surface_variant" android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
